.col-auto.text-start
  %i{ title: status_title, class: status_icon }
.col.text-start
  = link_to "#{hook_event.humanize} event", token_workflow_run_path(token_id, workflow_run)
  - if hook_action
    %span.ms-2.badge.text-bg-primary= hook_action.humanize
.col.text-start
  - if event_source_name
    - field_to_filter_by = hook_event.in?(['pull_request', 'Merge Request Hook']) ? 'pr_mr' : 'commit_sha'
    = link_to "Filter by #{formatted_event_source_name}", "?#{field_to_filter_by}=#{event_source_name}", { class: 'link-secondary' }
    \-
    = link_to "Go to #{formatted_event_source_name}", event_source_url, { class: 'link-secondary' }
  - else
    Unknown source
.col.text-end
  = workflow_run.created_at
