- @pagetitle = requests_listing_pagetitle(@user_or_group)

.card
  %div
    %ul.card-header.nav.nav-tabs.pt-2.px-3.pb-0.flex-nowrap
      %li.nav-item
      = link_to(group_path(@user_or_group), class: 'nav-link', title: 'Requests') do
        Group Members
        %span.badge.text-bg-primary
          = @user_or_group.users.size
      %li.nav-item
        %a.nav-link.active
          Group Requests
  .card-body
    .tab-content
      .tab-pane.active
        %h3 Group Requests
        = render(partial: 'webui/shared/bs_requests/form',
                 locals: { selected_filter: @selected_filter,
                           bs_requests_creators: @bs_requests_creators,
                           viewed_object: 'Any Group You Belong',
                           url: @url,
                           bs_requests: @bs_requests,
                           displayed_involvement: %i[incoming review]})
