<%- token_description = Token::Workflow.find(event['token_id']).description -%>
<%- recipient = event['user_login'].present? ? 'you' : "group '#{event['group_title']}'" -%>
The user <%= event['who'] -%>
<% if event['action'] == 'share' -%>
 shared token '<%= token_description %>' with <%= recipient %>.
<% else -%>
 removed <%= recipient %> from token '<%= token_description %>'.
<% end -%>
